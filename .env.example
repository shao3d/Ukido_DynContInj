# OpenRouter API Configuration
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configuration (optional)
# Default model for routing/classification through OpenRouter
# ROUTER_MODEL=google/gemini-2.5-flash
# MODEL=google/gemini-2.5-flash  # Backward-compatible alias

# Model for generating final answers (optional)
# Default: anthropic/claude-3.5-haiku
# MODEL_ANSWER=anthropic/claude-3.5-haiku
# ANSWER_MODEL=anthropic/claude-3.5-haiku  # Backward-compatible alias

# Model for translation and humor generation (optional)
# TRANSLATION_MODEL=anthropic/claude-3.5-haiku
# ZHVANETSKY_MODEL=anthropic/claude-3.5-haiku
# HUMOR_MODEL=anthropic/claude-3.5-haiku  # Backward-compatible alias

# HubSpot CRM Configuration
# Get your Private App Token at: https://app.hubspot.com/settings/private-apps
HUBSPOT_PRIVATE_APP_TOKEN=your_hubspot_private_app_token_here

# Your HubSpot Portal ID (find it in HubSpot settings)
HUBSPOT_PORTAL_ID=your_hubspot_portal_id_here

# Public API surface (optional)
# Set ADMIN_API_TOKEN to enable protected admin endpoints like /metrics and /clear_history
# ADMIN_API_TOKEN=change_me
# CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://shao3d.github.io
# CORS_ALLOW_CREDENTIALS=true

# Persistence and test/prod behavior (optional)
# PERSISTENCE_BASE_PATH=data/persistent_states
# DETERMINISTIC_MODE=false

# Server Configuration (optional)
# HOST=0.0.0.0
# PORT=8000
